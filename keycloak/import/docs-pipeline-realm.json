{
  "realm": "docs-pipeline",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "registrationEmailAsUsername": false,
  "rememberMe": false,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "defaultSignatureAlgorithm": "RS256",
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,

  "organizationsEnabled": true,
  "organizations": [
    {
      "name": "tenant-a",
      "alias": "tenant-a",
      "enabled": true,
      "description": "Example tenant A (maps 1:1 to instance 'tenant-a').",
      "redirectUrl": "",
      "domains": [
        { "name": "tenant-a.example.com", "verified": false }
      ],
      "attributes": {
        "instance": ["tenant-a"]
      }
    },
    {
      "name": "tenant-b",
      "alias": "tenant-b",
      "enabled": true,
      "description": "Example tenant B (maps 1:1 to instance 'tenant-b').",
      "redirectUrl": "",
      "domains": [
        { "name": "tenant-b.example.com", "verified": false }
      ],
      "attributes": {
        "instance": ["tenant-b"]
      }
    }
  ],

  "groups": [
    {
      "name": "tenant-a",
      "path": "/tenant-a",
      "attributes": {},
      "realmRoles": [],
      "clientRoles": {},
      "subGroups": [
        { "name": "admin", "path": "/tenant-a/admin", "attributes": {}, "realmRoles": [], "clientRoles": {}, "subGroups": [] },
        { "name": "content_curator", "path": "/tenant-a/content_curator", "attributes": {}, "realmRoles": [], "clientRoles": {}, "subGroups": [] },
        { "name": "viewer", "path": "/tenant-a/viewer", "attributes": {}, "realmRoles": [], "clientRoles": {}, "subGroups": [] }
      ]
    },
    {
      "name": "tenant-b",
      "path": "/tenant-b",
      "attributes": {},
      "realmRoles": [],
      "clientRoles": {},
      "subGroups": [
        { "name": "admin", "path": "/tenant-b/admin", "attributes": {}, "realmRoles": [], "clientRoles": {}, "subGroups": [] },
        { "name": "content_curator", "path": "/tenant-b/content_curator", "attributes": {}, "realmRoles": [], "clientRoles": {}, "subGroups": [] },
        { "name": "viewer", "path": "/tenant-b/viewer", "attributes": {}, "realmRoles": [], "clientRoles": {}, "subGroups": [] }
      ]
    }
  ],

  "roles": {
    "realm": [
      {
        "name": "master_admin",
        "description": "Platform super-admin. Unrestricted across all tenants/instances.",
        "composite": false,
        "clientRole": false
      }
    ]
  },

  "clients": [
    {
      "clientId": "docs-pipeline-api",
      "description": "Bearer-only resource server. Validates access tokens for the pipeline API; issues none.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [],
      "webOrigins": [],
      "fullScopeAllowed": false,
      "protocolMappers": [],
      "defaultClientScopes": ["basic", "web-origins", "acr", "roles", "profile", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access", "microprofile-jwt"]
    },
    {
      "clientId": "docs-pipeline-ui",
      "description": "Public SPA. Authorization Code + PKCE (S256).",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": false,
      "redirectUris": [
        "https://*.example.com/*",
        "http://localhost:*/*"
      ],
      "webOrigins": [
        "https://*.example.com",
        "http://localhost:*"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      },
      "fullScopeAllowed": true,
      "defaultClientScopes": ["basic", "web-origins", "acr", "roles", "profile", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access", "microprofile-jwt"],
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "true",
            "claim.name": "groups",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "claim.name": "roles",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "instances-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "user.attribute": "instances",
            "claim.name": "instances",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "envs-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "user.attribute": "envs",
            "claim.name": "envs",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "docs-pipeline-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "docs-pipeline-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "docs-pipeline-test-cli",
      "description": "Public CLI client for local/dev testing. Direct Access Grants (password) only.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": false,
      "redirectUris": [],
      "webOrigins": [],
      "fullScopeAllowed": true,
      "defaultClientScopes": ["basic", "web-origins", "acr", "roles", "profile", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access", "microprofile-jwt"],
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "true",
            "claim.name": "groups",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "claim.name": "roles",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "instances-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "user.attribute": "instances",
            "claim.name": "instances",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "envs-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "user.attribute": "envs",
            "claim.name": "envs",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "docs-pipeline-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "docs-pipeline-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "docs-pipeline-admin",
      "description": "Confidential service-account client. The backend uses its client-credentials (client_id + secret) token to call the Keycloak Admin API and create/manage Organizations, users, groups, and group memberships. No 'secret' is shipped here — Keycloak generates one on import; regenerate/read it at deploy (scripts/keycloak_bootstrap_docs_pipeline.py) and put the real value in the backend .env as KEYCLOAK_ADMIN_CLIENT_SECRET.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [],
      "webOrigins": [],
      "fullScopeAllowed": true,
      "defaultClientScopes": ["basic", "web-origins", "acr", "roles", "profile", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access", "microprofile-jwt"]
    }
  ],

  "users": [
    {
      "username": "service-account-docs-pipeline-admin",
      "enabled": true,
      "serviceAccountClientId": "docs-pipeline-admin",
      "clientRoles": {
        "realm-management": ["realm-admin"]
      }
    }
  ],

  "keycloakVersion": "26.3.2"
}
