# Document Ingestion Pipeline — environment contract
# Copy to .env and override for your deployment.

# --- Core services ---
TEMPORAL_HOST=localhost:7233
MARQO_URL=http://localhost:8882
MARQO_INDEX_NAME=documents-index
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=documents
DOCUMENT_DB_PATH=/data/documents.db
LANG_DETECT_URL=http://lang-detect:3000

# --- CORS / rate limits ---
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_UPLOAD=10/minute
ALLOWED_FILE_PATHS=/app/books,/data/documents

# --- OCR (Chandra) ---
OCR_PROVIDER=chandra
OCR_MODEL=chandra
CHANDRA_VLLM_BASE_URL=http://localhost:8010/v1
CHANDRA_INFERENCE_MODE=hf
CHANDRA_MAX_OUTPUT_TOKENS=12288
CHANDRA_OCR_MAX_WORKERS=4
CHANDRA_HF_HOME=
HF_HOME=

# --- Translation (Gemma vLLM) ---
TRANSLATION_PROVIDER=gemma_vllm
TRANSLATION_MODEL=gemma-4-31b-it
TRANSLATION_VLLM_BASE_URL=http://localhost:8020/v1
TRANSLATION_API_KEY=
TRANSLATION_PAGE_CONCURRENCY=1
TRANSLATION_MAX_RETRIES=6
TRANSLATION_RETRY_BASE_SECONDS=2.0

# --- Domain tagging ---
DOMAIN_TAGGING_ENABLED=true
DOMAIN_TAGGING_PROVIDER=gemma_vllm
DOMAIN_TAGGING_MODEL=gemma-4-31b-it
DOMAIN_TAGGING_VLLM_BASE_URL=http://localhost:8020/v1
DOMAIN_TAGGING_STRICT_TAXONOMY=true
DOMAIN_TAXONOMY_PATH=

# --- Chunking ---
CHUNKING_PROVIDER=qwen_vllm
CHUNKING_MODEL=qwen3.5-27b
CHUNKING_VLLM_BASE_URL=http://localhost:8005/v1
CHUNKING_API_KEY=
CHUNKING_TARGET_CHUNK_TOKENS=450
CHUNKING_MAX_CHUNK_TOKENS=450
CHUNKING_MIN_CHUNK_TOKENS=100
CHUNKING_OVERLAP_TOKENS=128
CHUNKING_MAX_PAGES_PER_CHUNK=8
CHUNKING_PAGE_WINDOW_SIZE=8
CHUNKING_QWEN_ENABLE_THINKING=false
TEMPORAL_MAX_CONCURRENT_ACTIVITIES=4

# --- Document metadata (optional) ---
DOCUMENT_METADATA_CSV_PATH=/app/workspace/document_manifest.csv
DOCUMENT_DESCRIPTIONS_JSONL_PATH=/app/workspace/document_descriptions.jsonl

# --- Provenance / UI link builders (optional) ---
DOCS_PIPELINE_API_URL=http://localhost:8001
DOCS_PIPELINE_UI_URL=http://localhost:3000

DOMAIN_TAGGING_CONCURRENCY=4

# --- Auth / Keycloak (backend gates) ---
# FE and BE Keycloak settings MUST describe the same realm/issuer.
# ui/.env (browser):
#   VITE_KEYCLOAK_URL=https://auth-vistaar.da.gov.in/auth
#   VITE_KEYCLOAK_REALM=bharat-vistaar
#   VITE_KEYCLOAK_CLIENT_ID=bharat-vistaar
#   VITE_KEYCLOAK_IDP_HINT=google
#   VITE_AUTH_ENABLED=true
#
# true = local bypass (full permissions) but still reads name/email/roles from JWT when sent.
# false = require valid Bearer JWT (signature + issuer via JWKS). Do not enable until UI SSO works.
AUTH_DISABLED=true
# Must match JWT `iss` from the FE Keycloak realm.
KEYCLOAK_ISSUER=https://auth-vistaar.da.gov.in/auth/realms/bharat-vistaar
# Leave empty to skip audience checks (recommended for public SPA clients).
# Set e.g. account or bharat-vistaar only if your access tokens always carry that aud.
KEYCLOAK_AUDIENCE=
KEYCLOAK_JWKS_URL=https://auth-vistaar.da.gov.in/auth/realms/bharat-vistaar/protocol/openid-connect/certs
KEYCLOAK_JWT_LEEWAY_SECONDS=30
# Optional local compose Keycloak (only if you run Keycloak in docker instead of production):
# KEYCLOAK_ISSUER=http://localhost:8082/auth/realms/docs-pipeline
# KEYCLOAK_JWKS_URL=http://localhost:8082/auth/realms/docs-pipeline/protocol/openid-connect/certs
# KEYCLOAK_AUDIENCE=docs-pipeline-api
KEYCLOAK_PORT=8082
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_DB_PASSWORD=change-me
KEYCLOAK_DB_DATA_PATH=./data/keycloak-db
# Default tenant/instance for new docs and legacy NULL/empty rows (migration backfills this).
DEFAULT_INSTANCE=default
