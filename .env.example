# Document Ingestion Pipeline — environment contract
# Copy to .env and fill secrets for your deployment.
# Used by: docker compose -f docker-compose.prod.yml --env-file .env

# --- Core services ---
# TEMPORAL_HOST / MINIO_ENDPOINT / LANG_DETECT_URL are overridden inside
# docker-compose.prod.yml to Docker service DNS (temporal, minio, lang-detect).
TEMPORAL_HOST=localhost:7233
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=documents
DOCUMENT_DB_PATH=./data/documents.db
LANG_DETECT_URL=http://localhost:3001

# --- Vector backend (Qdrant) ---
VECTOR_BACKEND=qdrant
# Local: http://localhost:6333
# Remote reverse-proxy: https://dev-vistaar.da.gov.in/qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=test_doc_pipeline
QDRANT_TIMEOUT_SECONDS=30

# --- Embeddings ---
# Default: local SentenceTransformer (requires sentence-transformers in the image).
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024
EMBEDDING_VECTOR_SIZE=1024
# Prefer remote embeddings on slim/CPU hosts (skips torch in the worker):
# EMBEDDING_PROVIDER=openai_compatible
# EMBEDDING_BASE_URL=https://dev-vistaar.da.gov.in/<embeddings>/v1
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=intfloat/multilingual-e5-large

# --- Hugging Face (local SentenceTransformer model download/cache) ---
HF_TOKEN=
HF_HOME=/opt/hf-cache
# Host path is bind-mounted into api/worker at the same path.
# On server: sudo mkdir -p /opt/hf-cache && sudo chown -R 1000:1000 /opt/hf-cache
# (or chown to the uid the container runs as)

# --- CORS / limits ---
# Browser origins allowed to call the API (comma-separated, no spaces preferred).
# Production registry:
CORS_ORIGINS=https://registry-sandbox-vistaar.da.gov.in
# Local UI: CORS_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_UPLOAD=10/minute
ALLOWED_FILE_PATHS=./books,./data/documents

# --- OCR (Mistral Document AI) ---
OCR_PROVIDER=mistral
OCR_MODEL=mistral-ocr-latest
MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_OCR_API_URL=https://api.mistral.ai/v1/ocr
OCR_SEGMENT_PAGES=20
OCR_REQUEST_TIMEOUT_SECONDS=300
# Alternatives: OCR_PROVIDER=mock|pypdf|chandra

# --- LLM: Gemma 4 (translation + domain tagging) ---
AGRINET_GEMMA_BASE_URL=https://dev-vistaar.da.gov.in/gemma4
AGRINET_GEMMA_MODEL_NAME=google/gemma-4-31b-it
# Optional if gateway needs a key:
# AGRINET_GEMMA_API_KEY=

TRANSLATION_PROVIDER=gemma_vllm
TRANSLATION_MODEL=google/gemma-4-31b-it
TRANSLATION_VLLM_BASE_URL=https://dev-vistaar.da.gov.in/gemma4
TRANSLATION_PAGE_CONCURRENCY=1

DOMAIN_TAGGING_ENABLED=true
DOMAIN_TAGGING_PROVIDER=gemma_vllm
DOMAIN_TAGGING_MODEL=google/gemma-4-31b-it
DOMAIN_TAGGING_VLLM_BASE_URL=https://dev-vistaar.da.gov.in/gemma4
DOMAIN_TAGGING_STRICT_TAXONOMY=true

# --- Chunking ---
CHUNKING_PROVIDER=deterministic
CHUNKING_MODEL=deterministic
CHUNKING_TARGET_CHUNK_TOKENS=450
TEMPORAL_MAX_CONCURRENT_ACTIVITIES=4

# --- Host port binds (localhost only; for host nginx) ---
# Chosen to avoid clashes on shared registry host:
#   oan-redis          → 8001
#   bharat-vistaar-docs-nginx → 8088
#   keycloak           → 8081
#   notification svc   → 8082
API_HOST_PORT=8011
UI_HOST_PORT=3011
TEMPORAL_UI_PORT=8090
# temporal-ui is under compose profile "ops" — start with:
#   docker compose -f docker-compose.prod.yml --profile ops up -d temporal-ui

# --- App URLs (public, after nginx) ---
DOCS_PIPELINE_API_URL=https://registry-sandbox-vistaar.da.gov.in/docs-pipeline-api
DOCS_PIPELINE_UI_URL=https://registry-sandbox-vistaar.da.gov.in/docs-pipeline

# --- Auth / Keycloak (API) ---
AUTH_DISABLED=false
KEYCLOAK_ISSUER=https://auth-vistaar.da.gov.in/auth/realms/bharat-vistaar
KEYCLOAK_AUDIENCE=
KEYCLOAK_JWKS_URL=https://auth-vistaar.da.gov.in/auth/realms/bharat-vistaar/protocol/openid-connect/certs
DEFAULT_INSTANCE=default

# --- UI build args (baked into Vite at image build time) ---
VITE_API_BASE=/docs-pipeline-api
VITE_BASE=/docs-pipeline/
VITE_AUTH_ENABLED=true
VITE_KEYCLOAK_URL=https://auth-vistaar.da.gov.in/auth
VITE_KEYCLOAK_REALM=bharat-vistaar
VITE_KEYCLOAK_CLIENT_ID=bharat-vistaar
