# ---------------------------------------------------------------------------
# Docs Pipeline maintainer UI configuration.
# Read by Vite; anything the browser needs must be prefixed with VITE_.
# ---------------------------------------------------------------------------

# Backend + Marqo proxy targets used by the Vite dev server (see vite.config.js).
VITE_API_PROXY_TARGET=http://api:8001
VITE_MARQO_PROXY_TARGET=http://marqo:8882

# --- Keycloak / OIDC authentication ----------------------------------------
# When false (the default) the UI runs fully open with no login — handy for
# local development without a Keycloak. Set to true to require sign-in.
VITE_AUTH_ENABLED=false

# Base URL of the Keycloak server. Include the /auth path segment if your
# Keycloak is served under it (legacy layout). Example: https://auth.example.com/auth
VITE_KEYCLOAK_URL=https://auth.example.com/auth

# Realm that holds the maintainer accounts.
VITE_KEYCLOAK_REALM=docs-pipeline

# Public client id (Authorization Code + PKCE / standard flow).
VITE_KEYCLOAK_CLIENT_ID=docs-pipeline-ui
