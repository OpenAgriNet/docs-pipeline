# ---------------------------------------------------------------------------
# Docs Pipeline maintainer UI configuration.
# Read by Vite; anything the browser needs must be prefixed with VITE_.
# Copy to ui/.env for local overrides.
# ---------------------------------------------------------------------------

# Backend + Marqo proxy targets used by the Vite dev server (see vite.config.js).
# For local non-Docker runs use localhost targets (below).
VITE_API_PROXY_TARGET=http://localhost:8001
VITE_MARQO_PROXY_TARGET=http://localhost:8882

# --- Keycloak / OIDC authentication ----------------------------------------
# When false (the default) the UI runs fully open with no login — handy for
# local development without Keycloak. Set to true to require sign-in.
VITE_AUTH_ENABLED=false

# Production Bharat Vistaar Keycloak (match vistaar-platform)
VITE_KEYCLOAK_URL=https://auth-vistaar.da.gov.in/auth
VITE_KEYCLOAK_REALM=bharat-vistaar
VITE_KEYCLOAK_CLIENT_ID=bharat-vistaar
VITE_KEYCLOAK_IDP_HINT=google

# Keycloak client Valid Redirect URIs must include:
#   http://localhost:<port>/auth/sso-callback
#   http://localhost:<port>/login
#   https://<your-app-origin>/auth/sso-callback
#   https://<your-app-origin>/login
